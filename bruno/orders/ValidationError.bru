meta {
  name: Validation Error
  type: http
  seq: 3
}

post {
  url: {{base_url}}/orders
  body: json
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "customerEmail": "invalido",
    "totalCents": 0
  }
}

assert {
  res.status: eq 400
  res.body.message: isDefined
  res.body.error: eq "Bad Request"
}
