import { Injectable, OnModuleInit, OnModuleDestroy, Logger } from '@nestjs/common';
import { MongoClient } from 'mongodb';
import { connect, type Channel, type ChannelModel } from 'amqplib';
import { randomUUID } from 'crypto';
import { Registry, collectDefaultMetrics, Counter } from 'prom-client';
import { ORDER_CREATED_EVENT, type OrderCreatedEvent } from '@portfolio/contracts';

const registry = new Registry();
collectDefaultMetrics({ register: registry });
const ordersCreated = new Counter({
  name: 'orders_created_total',
  help: 'Created orders',
  registers: [registry],
});

@Injectable()
export class OrderService implements OnModuleInit, OnModuleDestroy {
  private readonly logger = new Logger(OrderService.name);
  private mongo!: MongoClient;
  private rabbit!: ChannelModel;
  private channel!: Channel;

  async onModuleInit(): Promise<void> {
    this.mongo = new MongoClient(
      process.env.MONGO_URL ?? 'mongodb://localhost:27017/order-service',
    );
    await this.mongo.connect();
    this.rabbit = await connect(
      process.env.RABBIT_URL ?? 'amqp://guest:guest@localhost:5672',
    );
    this.channel = await this.rabbit.createChannel();
    await this.channel.assertExchange('orders', 'topic', { durable: true });
  }

  async onModuleDestroy(): Promise<void> {
    if (this.channel) {
      await this.channel.close();
    }
    if (this.rabbit) {
      await this.rabbit.close();
    }
    if (this.mongo) {
      await this.mongo.close();
    }
  }

  async getMetrics(): Promise<string> {
    return registry.metrics();
  }

  async createOrder(
    customerEmail: string,
    totalCents: number,
    headerCorrelationId?: string,
  ): Promise<{ id: string; correlationId: string }> {
    // Explicit null checks — fail fast if connections are missing
    if (!this.mongo) {
      throw new Error('MongoDB not initialized');
    }
    if (!this.channel) {
      throw new Error('RabbitMQ channel not initialized');
    }

    const orderId = randomUUID();
    const correlationId = headerCorrelationId ?? randomUUID();

    await this.mongo.db().collection('orders').insertOne({
      orderId,
      customerEmail,
      totalCents,
      correlationId,
      createdAt: new Date(),
    });

    const event: OrderCreatedEvent = {
      eventId: randomUUID(),
      correlationId,
      orderId,
      customerEmail,
      totalCents,
      occurredAt: new Date().toISOString(),
    };

    this.channel.publish(
      'orders',
      ORDER_CREATED_EVENT,
      Buffer.from(JSON.stringify(event)),
      {
        contentType: 'application/json',
        correlationId,
        persistent: true,
      },
    );

    ordersCreated.inc();
    this.logger.log(
      JSON.stringify({
        level: 'info',
        message: 'order.created published',
        correlationId,
        orderId,
      }),
    );

    return { id: orderId, correlationId };
  }
}
